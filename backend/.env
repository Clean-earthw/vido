# --- Backblaze B2 (parent CLAUDE.md standard names — DO NOT rename) ---
# Region is bucket-derived (e.g. us-west-004, eu-central-003).
# B2_ENDPOINT is not needed — genblaze-s3 derives it from B2_REGION.
B2_REGION=<region>
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=

# --- Provider keys ---
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=
NVIDIA_API_KEY=nvapi-...
DECART_API_KEY=
GMI_API_KEY=

# --- Model overrides (defaults shipped in services/api/app/config.py) ---
# Stage A — storyboard chat (OpenAI; structured output via response_format).
CHAT_MODEL=gpt-4.1-nano
# Stage B0/B1 — reference + keyframe image (Google Imagen via ImagenProvider).
# The Gemini API serves Imagen 4.0 (3.0 is retired). `imagen-4.0-generate-001`
# is the flagship default; `-ultra-generate-001` is the max-quality upgrade and
# `-fast-generate-001` the cheaper per-scene tier. Flip via this env var.
IMAGE_MODEL=imagen-4.0-generate-001
# Stage B2 — image-to-video. Decart RETIRED image-to-video (its Lucy models
# are video-to-video now), so the default uses GMICloud's Kling Image2Video.
# "gmicloud" (default) or "decart"; if the selected provider's key is missing
# the backend swaps to whichever IS configured + logs it, so the run still
# completes. VIDEO_MODEL only applies when VIDEO_PROVIDER=decart.
VIDEO_PROVIDER=gmicloud
GMI_VIDEO_MODEL=Kling-Image2Video-V2.1-Master
VIDEO_MODEL=lucy-2.1
# Stage B2 — NVIDIA Magpie TTS. The `nvidia/` namespace is required — a bare
# `magpie-tts-multilingual` 404s the NIM genai endpoint.
TTS_MODEL=nvidia/magpie-tts-multilingual
# Stage B2 — GMICloud music. `MiniMax-Music-1` is retired upstream (404).
MUSIC_MODEL=minimax-music-2.5

# --- API surface ---
# Comma-separated origins for CORS. Next dev falls back to :3001 when :3000
# is taken — keep both in the allowlist so re-binding doesn't break the UI.
API_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Frontend → backend URL. The Next app calls FastAPI directly (no proxy
# route); change this if the API binds to a different host/port. The
# value MUST be inlined into the client bundle, hence NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Optional ---
# LOG_LEVEL=DEBUG floods stdout with per-step prompts, every SSE frame
# the backend yields, every presigned-URL handoff, all B2/boto3 HTTP
# requests, and Genblaze tracer chatter. Use it when diagnosing a stuck
# pipeline; flip back to INFO once you've found the issue.
LOG_LEVEL=INFO
OTEL_ENDPOINT=
STEP_CACHE_DIR=.cache/explainers
